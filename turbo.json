{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "globalDependencies": ["yarn.lock"],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "DATABASE_URL",
    "DATABASE_DIRECT_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "CALENDSO_ENCRYPTION_KEY",
    "CALCOM_APP_CREDENTIAL_ENCRYPTION_KEY",
    "CALCOM_LICENSE_KEY",
    "CALCOM_ENV",
    "CALCOM_TELEMETRY_DISABLED",
    "NEXTAUTH_COOKIE_DOMAIN",
    "NEXT_PUBLIC_WEBAPP_URL",
    "NEXT_PUBLIC_WEBSITE_URL",
    "NEXT_PUBLIC_API_V2_URL",
    "VERCEL_ENV",
    "VERCEL_URL"
  ],
  "tasks": {
    "@calcom/prisma#build": {
      "cache": false,
      "dependsOn": ["post-install"]
    },
    "@calcom/prisma#db-migrate": {
      "cache": false,
      "dependsOn": ["@calcom/prisma#db-up"],
      "inputs": ["./schema.prisma", "./migrations/**/*.sql"]
    },
    "@calcom/prisma#db-seed": {
      "cache": false,
      "dependsOn": ["@calcom/prisma#db-deploy"]
    },
    "@calcom/prisma#db-up": {
      "cache": false
    },
    "@calcom/prisma#dx": {
      "cache": false,
      "dependsOn": ["@calcom/prisma#db-up"]
    },
    "@calcom/prisma#post-install": {
      "inputs": ["./schema.prisma", "./prisma/schema.prisma"],
      "outputs": [
        "$TURBO_ROOT$/node_modules/@prisma/client/**",
        "$TURBO_ROOT$/node_modules/@prisma/admin-client/**",
        "generated/**",
        "enums/**",
        "zod/**",
        "$TURBO_ROOT$/packages/kysely/types.ts"
      ]
    },
    "@calcom/prisma#db-reset": {
      "cache": false
    },
    "@calcom/app-store#build:types": {
      "outputs": ["types/**"]
    },
    "@calcom/trpc#build": {
      "dependsOn": ["@calcom/prisma#post-install"],
      "inputs": [
        "server/**",
        "react/**",
        "tsconfig.server.json",
        "tsconfig.react.json",
        "package.json"
      ],
      "outputs": ["./types"]
    },
    "@calcom/atoms#build-npm": {
      "outputs": ["dist/**", "globals.min.css"]
    },
    "@calcom/app-store-cli#build": {
      "inputs": [
        "$TURBO_ROOT$/packages/app-store/**/package.json",
        "$TURBO_ROOT$/packages/app-store/**/config.json",
        "$TURBO_ROOT$/packages/app-store/**/api/**",
        "$TURBO_ROOT$/packages/app-store/**/components/**",
        "$TURBO_ROOT$/packages/app-store/**/lib/**",
        "$TURBO_ROOT$/packages/app-store/**/pages/**",
        "$TURBO_ROOT$/packages/app-store-cli/src/**"
      ],
      "outputs": [
        "$TURBO_ROOT$/packages/app-store/*.generated.ts",
        "$TURBO_ROOT$/packages/app-store/*.generated.tsx"
      ]
    },
    "@calcom/embed-core#build": {
      "outputs": ["$TURBO_ROOT$/apps/web/public/embed/**"],
      "env": [
        "EMBED_PUBLIC_VERCEL_URL",
        "EMBED_PUBLIC_WEBAPP_URL",
        "EMBED_PUBLIC_EMBED_FINGER_PRINT",
        "EMBED_PUBLIC_EMBED_VERSION"
      ]
    },
    "@calcom/embed-react#type-check": {
      "dependsOn": ["@calcom/embed-core#build", "@calcom/embed-snippet#build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "db-deploy": {
      "cache": false,
      "inputs": ["./migrations/**/*.sql", "./prisma/migrations/**/*.sql"]
    },
    "db-seed": {},
    "deploy": {
      "cache": false,
      "dependsOn": ["@calcom/web#build"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["//#env-check:common", "//#env-check:app-store"],
      "cache": false,
      "persistent": true
    },
    "dev:trigger": {
      "inputs": ["./.env"],
      "env": ["TRIGGER_DEV_PROJECT_REF"],
      "cache": false,
      "persistent": true
    },
    "deploy:trigger:prod": {
      "inputs": ["./.env"],
      "env": [
        "TRIGGER_DEV_PROJECT_REF",
        "TRIGGER_API_URL",
        "TRIGGER_SECRET_KEY",
        "TRIGGER_DEV_VERCEL_ACCESS_TOKEN",
        "TRIGGER_DEV_VERCEL_PROJECT_ID",
        "TRIGGER_DEV_VERCEL_TEAM_ID"
      ],
      "cache": false
    },
    "deploy:trigger:staging": {
      "inputs": ["./.env"],
      "env": [
        "TRIGGER_DEV_PROJECT_REF",
        "TRIGGER_API_URL",
        "TRIGGER_SECRET_KEY",
        "TRIGGER_DEV_VERCEL_ACCESS_TOKEN",
        "TRIGGER_DEV_VERCEL_PROJECT_ID",
        "TRIGGER_DEV_VERCEL_TEAM_ID"
      ],
      "cache": false
    },
    "dx": {
      "dependsOn": ["//#env-check:common", "//#env-check:app-store"],
      "cache": false
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "lint:report": {
      "outputs": ["lint-results"]
    },
    "post-install": {
      "dependsOn": [],
      "outputs": [
        "$TURBO_ROOT$/node_modules/@prisma/client/**",
        "$TURBO_ROOT$/node_modules/@prisma/admin-client/**"
      ],
      "inputs": ["./schema.prisma", "./prisma/schema.prisma"]
    },
    "start": {},
    "embed-tests": {
      "cache": false
    },
    "embed-tests-quick": {
      "cache": false
    },
    "type-check": {
      "cache": false,
      "dependsOn": ["@calcom/trpc#build"]
    },
    "type-check:ci": {
      "cache": false,
      "dependsOn": ["@calcom/trpc#build"]
    },
    "embed-tests-update-snapshots:ci": {
      "cache": false,
      "dependsOn": [
        "@calcom/prisma#db-seed",
        "@calcom/web#build",
        "^build",
        "^embed-tests-update-snapshots:ci"
      ]
    },
    "//#env-check:common": {
      "cache": false,
      "inputs": ["./.env.example", "./.env"],
      "outputs": ["./.env"]
    },
    "//#env-check:app-store": {
      "cache": false,
      "inputs": ["./.env.appStore.example", "./.env.appStore"],
      "outputs": ["./.env.appStore"]
    },
    "//#test": {
      "cache": false,
      "env": [
        "INTEGRATION_TEST_MODE",
        "INTEGRATION_TESTS",
        "MOCK_PAYMENT_APP_ENABLED",
        "PLAYWRIGHT_HEADLESS",
        "PLAYWRIGHT_TEST_BASE_URL",
        "E2E_TEST_APPLE_CALENDAR_EMAIL",
        "E2E_TEST_APPLE_CALENDAR_PASSWORD",
        "E2E_TEST_CALCOM_QA_EMAIL",
        "E2E_TEST_CALCOM_QA_PASSWORD",
        "E2E_TEST_CALCOM_QA_GCAL_CREDENTIALS",
        "E2E_TEST_CALCOM_GCAL_KEYS",
        "E2E_TEST_MAILHOG_ENABLED",
        "E2E_TEST_OIDC_CLIENT_ID",
        "E2E_TEST_OIDC_CLIENT_SECRET",
        "E2E_TEST_OIDC_PROVIDER_DOMAIN",
        "E2E_TEST_OIDC_USER_EMAIL",
        "E2E_TEST_OIDC_USER_PASSWORD",
        "E2E_TEST_SAML_ADMIN_EMAIL",
        "E2E_TEST_SAML_ADMIN_PASSWORD",
        "ATOMS_E2E_API_URL",
        "ATOMS_E2E_OAUTH_CLIENT_ID",
        "ATOMS_E2E_OAUTH_CLIENT_ID_BOOKER_EMBED",
        "ATOMS_E2E_OAUTH_CLIENT_SECRET",
        "ATOMS_E2E_ORG_ID",
        "ATOMS_E2E_APPLE_ID",
        "ATOMS_E2E_APPLE_CONNECT_APP_SPECIFIC_PASSCODE"
      ]
    }
  }
}
