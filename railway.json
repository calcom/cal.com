{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "NODE_OPTIONS='--max-old-space-size=8192' yarn turbo run build --filter=@calcom/web"
  },
  "deploy": {
    "startCommand": "yarn workspace @calcom/web start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
