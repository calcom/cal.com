{
  "name": "@calcom/cli",
  "version": "0.0.1",
  "description": "CLI for Cal.com API v2",
  "license": "MIT",
  "bin": {
    "calcom": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "yarn generate && tsc -p tsconfig.json && cp -r src/templates dist/",
