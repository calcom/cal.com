{
  "name": "@calcom/kv",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    "./kv-adapter": "./src/kv-adapter.ts",
    "./create-kv-adapter": "./src/create-kv-adapter.ts"
  },
  "typesVersions": {
    "*": {
      "kv-adapter": [
        "./src/kv-adapter.ts"
      ],
      "create-kv-adapter": [
        "./src/create-kv-adapter.ts"
      ]
    }
  },
  "scripts": {
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "lint:report": "biome lint --reporter json src > ../../../../lint-results/kv-adapters.json",
    "type-check": "tsc --pretty --noEmit",
    "type-check:ci": "tsc-absolute --pretty --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "1.37.0",
    "redis": "5.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@calcom/tsconfig": "workspace:*",
    "tsc-absolute": "1.0.0",
    "typescript": "5.9.3"
  }
}
