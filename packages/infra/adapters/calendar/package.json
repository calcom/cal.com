{
  "name": "@calcom/calendar-adapter",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    "./calendar-adapter": "./src/calendar-adapter.ts",
    "./calendar-adapter-types": "./src/calendar-adapter-types.ts",
    "./create-calendar-adapter": "./src/create-calendar-adapter.ts",
    "./observable-calendar-adapter": "./src/observable-calendar-adapter.ts"
  },
  "typesVersions": {
    "*": {
      "calendar-adapter": [
        "./src/calendar-adapter.ts"
      ],
      "calendar-adapter-types": [
        "./src/calendar-adapter-types.ts"
      ],
      "create-calendar-adapter": [
        "./src/create-calendar-adapter.ts"
      ],
      "observable-calendar-adapter": [
        "./src/observable-calendar-adapter.ts"
      ]
    }
  },
  "scripts": {
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "type-check": "tsc --pretty --noEmit",
    "type-check:ci": "tsc-absolute --pretty --noEmit"
  },
  "dependencies": {
    "@googleapis/calendar": "9.7.9",
    "ews-javascript-api": "0.11.0",
    "ical.js": "1.5.0",
    "tsdav": "2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@calcom/tsconfig": "workspace:*",
    "tsc-absolute": "1.0.0",
    "typescript": "5.9.3"
  }
}
