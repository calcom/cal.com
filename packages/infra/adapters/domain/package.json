{
  "name": "@calcom/domains",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    "./domain-manager": "./src/domain-manager.ts",
    "./create-domain-manager": "./src/create-domain-manager.ts",
    "./domain-adapter-error": "./src/lib/domain-adapter-error.ts"
  },
  "typesVersions": {
    "*": {
      "domain-manager": [
        "./src/domain-manager.ts"
      ],
      "create-domain-manager": [
        "./src/create-domain-manager.ts"
      ],
      "domain-adapter-error": [
        "./src/lib/domain-adapter-error.ts"
      ]
    }
  },
  "scripts": {
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "lint:report": "biome lint --reporter json src > ../../../../lint-results/domain-adapters.json",
    "type-check": "tsc --pretty --noEmit",
    "type-check:ci": "tsc-absolute --pretty --noEmit"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@calcom/tsconfig": "workspace:*",
    "tsc-absolute": "1.0.0",
    "typescript": "5.9.3"
  }
}
