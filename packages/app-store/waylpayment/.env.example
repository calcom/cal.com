# Cal.com public URL — used to build the absolute webhook callback URL sent to Wayl.
# Required. Example: https://cal.yourdomain.com
NEXT_PUBLIC_WEBAPP_URL=

# Encryption key for storing per-user Wayl API keys in the database.
# Generate with: openssl rand -base64 32
# Required.
CALCOM_APP_CREDENTIAL_ENCRYPTION_KEY=
