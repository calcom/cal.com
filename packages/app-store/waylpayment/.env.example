# Wayl Payment Gateway
# Get your API key from https://dashboard.thewayl.com/settings/api
WAYL_API_KEY=

# Webhook secret — set this to any strong random string,
# then configure the same value in your Wayl dashboard webhook settings
WAYL_WEBHOOK_SECRET=

# Cal.com public URL (used to build the webhook callback URL)
# Example: https://cal.yourdomain.com
NEXT_PUBLIC_WEBAPP_URL=
