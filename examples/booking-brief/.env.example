# ── Setup: copy this file to `.env` and fill values locally. Never commit `.env` or paste secrets into chat. ──
#
# Where to get each value:
#   CAL_WEBHOOK_SECRET  → https://app.cal.com/settings/developer/webhooks (create webhook → copy secret)
#   ANTHROPIC_API_KEY   → https://console.anthropic.com/settings/keys
#   ANTHROPIC_MODEL     → https://docs.anthropic.com/en/docs/about-claude/models (pick an ID your key can use)
#   SMTP_*              → Your provider, e.g.:
#                         Gmail app password: https://support.google.com/accounts/answer/185833
#                         Resend SMTP:       https://resend.com/docs/send-with-smtp
#                         Mailtrap (testing): https://mailtrap.io/ (inbox SMTP credentials)

# Cal.com webhook subscriber secret (optional for local `npm run test:webhook` if this is empty)
CAL_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

PORT=3000
